# Temren SaaS Configuration
PORT=8080
DATABASE_URL=postgres://temren:temren@localhost:5432/temren?sslmode=disable
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_EXPIRY=24h
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Worker
WORKER_CONCURRENCY=5
SCAN_TIMEOUT=30

# Webhooks (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
WEBHOOK_SECRET=

# AI providers (optional; first set key wins)
# Override model names without recompiling — see pkg/ai/{anthropic,openai,ollama}.go
ANTHROPIC_API_KEY=
TEMREN_ANTHROPIC_MODEL=claude-opus-4-7
OPENAI_API_KEY=
TEMREN_OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=
TEMREN_OLLAMA_MODEL=llama3
TEMREN_OLLAMA_URL=http://localhost:11434

# Plan limits
FREE_PLAN_TARGETS=1
PRO_PLAN_TARGETS=5
TEAM_PLAN_TARGETS=20
FREE_PLAN_SCANS=5
PRO_PLAN_SCANS=50
TEAM_PLAN_SCANS=200
