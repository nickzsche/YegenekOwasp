{
  "name": "temren",
  "displayName": "Temren OWASP Scanner",
  "description": "Run Temren security scans from VS Code",
  "version": "0.1.0",
  "publisher": "temren",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Security",
    "Testing"
  ],
  "activationEvents": [
    "onCommand:temren.scan",
    "onView:temren-vulnerabilities"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "temren.scan",
        "title": "Temren: Scan Target"
      },
      {
        "command": "temren.scanQuick",
        "title": "Temren: Quick Scan"
      },
      {
        "command": "temren.scanFull",
        "title": "Temren: Full Scan"
      },
      {
        "command": "temren.showResults",
        "title": "Temren: Show Results"
      },
      {
        "command": "temren.clearResults",
        "title": "Temren: Clear Results"
      },
      {
        "command": "temren.openDetail",
        "title": "Temren: Open Finding Detail"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "temren-vulnerabilities",
          "name": "Temren Vulnerabilities"
        }
      ]
    },
    "configuration": {
      "title": "Temren OWASP Scanner",
      "properties": {
        "temren.executablePath": {
          "type": "string",
          "default": "temren",
          "description": "Path to the temren CLI executable"
        },
        "temren.defaultTarget": {
          "type": "string",
          "default": "",
          "description": "Default target URL for scans"
        },
        "temren.defaultFormat": {
          "type": "string",
          "default": "json",
          "enum": [
            "json",
            "sarif",
            "text"
          ],
          "enumDescriptions": [
            "JSON output format",
            "SARIF output format",
            "Plain text output format"
          ],
          "description": "Default output format for scan results"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ -watch",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
